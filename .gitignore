# Go binaries
/catchy
/catchy.exe
*.exe
*.test
*.out

# Built frontend (regenerate with: cd web && npm run build)
# The .gitkeep placeholder is kept so //go:embed all:static still compiles.
/internal/api/static/*
!/internal/api/static/.gitkeep

